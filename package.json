{
  "name": "pt-frontend",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node -r module-alias/register dist/main/server.js",
    "start:dev": "nodemon --config nodemon.json",
    "lint": "stylelint **/*.scss -v -q && eslint . && prettier --check .",
    "lint:fix": "prettier --write . .github && eslint --fix",
    "build": "yarn webpack --config webpack.config.js",
    "build:prod": "NODE_ENV=production yarn webpack --mode production --config webpack.config.js",
    "build:server": "tsc",
    "test": "npx if-env CI=true && exit 0 || yarn test:unit",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:routes": "jest -c jest.routes.config.js",
    "test:a11y": "echo 'Accessibility tests implemented later in the pipeline'",
    "test:smoke": "NODE_TLS_REJECT_UNAUTHORIZED=0 jest -c jest.smoke.config.js",
    "test:functional": "NODE_TLS_REJECT_UNAUTHORIZED=0 yarn playwright install && codeceptjs run --steps",
    "cichecks": "yarn install && yarn build && yarn rebuild puppeteer && yarn lint && yarn test && yarn test:routes && yarn test:a11y",
    "postinstall": "husky || true",
    "lint-staged": "lint-staged"
  },
  "_moduleAliases": {
    "@router": "dist/main/router",
    "@routes": "dist/main/routes",
    "@modules": "dist/main/modules",
    "@services": "dist/main/services",
    "@utils": "dist/main/utils"
  },
