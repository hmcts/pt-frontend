{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "commonjs",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": false,
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "experimentalDecorators": true,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "lib": ["es2020", "dom", "dom.iterable"],
    "baseUrl": "src/main",
    "paths": {
      "@router/*": ["router/*"],
      "@routes/*": ["routes/*"],
      "@modules/*": ["modules/*"],
      "@utils/*": ["utils/*"]
    },
    "typeRoots": ["./node_modules/@types", "./src/main/types"],
    "types": ["jest", "node", "express"]
  },
  "include": ["src/main/**/*", "src/main/assets/locales/**/*", "src/test/unit/**/*"],
  "exclude": ["**/codecept.conf.ts", "**/__mocks__/*", "**/*.test.ts", "**/*.spec.ts"],
  "ts-node": {
    "files": true
  }
}
