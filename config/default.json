{
  "port": 4000,
  "useCSRFProtection": true,
  "appInsights": {
    "instrumentationKey": false
  },
  "security": {
    "referrerPolicy": "same-origin",
    "hsts": {
      "maxAge": 31536000,
      "includeSubDomains": true,
      "preload": true
    }
  },
  "api": {
    "url": "http://pt-api-aat.service.core-compute-aat.internal"
  },
  "ccd": {
    "url": "http://ccd-data-store-api-aat.service.core-compute-aat.internal",
    "caseTypeId": "PT"
  },
  "idam": {
    "authorizationURL": "https://idam-web-public.aat.platform.hmcts.net/login",
    "tokenURL": "https://idam-api.aat.platform.hmcts.net/o/token",
    "clientID": "pt-frontend",
    "clientSecret": "NEED TO INSERT SECRET",
    "systemUsername": "dummy_user",
    "systemPassword": "NEED TO INSERT SECRET",
    "caching": false
  },
  "oidc": {
    "accessTokenEarlyRefreshSeconds": 30
  },
  "authProvider": {
    "url": "http://rpe-service-auth-provider-aat.service.core-compute-aat.internal",
    "microservice": "pt_frontend",
    "secret": "NEED TO INSERT SECRET"
  },
  "session": {
    "redis-connection-string": "redis://localhost:6379",
    "pt-session-secret": "pt-supersecret",
    "prefix": "pt-session",
    "cookieName": "pt_session",
    "redis": {
      "ttlInSeconds": 5400
    },
    "timeout": {
      "sessionWarningMinutes": 10,
      "sessionTimeoutMinutes": 60,
      "checkIntervalSeconds": 10
    }
  }
}
