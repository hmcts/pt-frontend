{% extends "stepsTemplate.njk" %}

{% from "govuk/components/table/macro.njk" import govukTable %}

{% block content %}
  <h1 class="govuk-heading-l">{{ t('myApplications') }}</h1>
  <p class="govuk-body"><a href="/start-new-application" class="govuk-link">{{ t('startNewApplicationLinkText') }}</a></p>

  {% if applications %}
    {{ govukTable({
      head: [
        { text: t('myApplicationsTable.applicationNumberHeading') },
        { text: t('myApplicationsTable.createdHeading') },
        { text: t('myApplicationsTable.submittedOnHeading') },
        { text: t('myApplicationsTable.statusHeading') }
      ],
      rows: applications
    }) }}
  {% endif %}
{% endblock %}
